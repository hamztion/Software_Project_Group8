@startuml
left to right direction
title Hospital Management System - Use Case Diagram

skinparam backgroundColor white
skinparam shadowing false

actor Patient
actor Doctor
actor "Administrative Staff" as Admin
actor "Billing Officer" as Billing
actor "Laboratory Staff" as Lab
actor "Radiology Staff" as Radiology
actor Pharmacist

rectangle "Hospital Management System" {

  usecase "Register Account" as UC1
  usecase "Login" as UC2
  usecase "Book Appointment" as UC3
  usecase "View Medical Reports" as UC4
  usecase "View Billing Details" as UC5

  usecase "Manage Appointments" as UC6
  usecase "Access Patient Record" as UC7
  usecase "Update Medical Record" as UC8
  usecase "Write Prescription" as UC9
  usecase "Review Diagnostic Results" as UC10
  usecase "Request Lab Test" as UC11
  usecase "Request Radiology Test" as UC12

  usecase "Register Patient" as UC13
  usecase "Manage Patient Information" as UC14

  usecase "Upload Lab Results" as UC15
  usecase "Upload Radiology Report" as UC16

  usecase "Process Prescription" as UC17
  usecase "Dispense Medication" as UC18

  usecase "Generate Invoice" as UC19
  usecase "Record Payment" as UC20
}

Patient --> UC1
Patient --> UC2
Patient --> UC3
Patient --> UC4
Patient --> UC5

Doctor --> UC6
Doctor --> UC7
Doctor --> UC8
Doctor --> UC9
Doctor --> UC10
Doctor --> UC11
Doctor --> UC12

Admin --> UC13
Admin --> UC14
Admin --> UC6

Lab --> UC15
Radiology --> UC16

Pharmacist --> UC17
Pharmacist --> UC18

Billing --> UC19
Billing --> UC20

UC11 ..> UC10 : <<include>>
UC12 ..> UC10 : <<include>>
UC17 ..> UC18 : <<include>>

@enduml