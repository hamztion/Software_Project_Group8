@startuml
title Detailed Sequence Diagram - UC3: Prescription and Medication Dispensing

actor Doctor as doctor
actor Pharmacist as pharmacist
participant "Web / Mobile Portal" as portal
participant "Backend API" as api
database "Centralized Database" as db

doctor -> portal : Write prescription
portal -> api : Submit prescription details
api -> db : Save prescription
db --> api : Prescription saved
api --> portal : Return prescription confirmation
portal --> doctor : Display prescription confirmation

pharmacist -> portal : View prescription
portal -> api : Request prescription details
api -> db : Retrieve prescription details
db --> api : Prescription details returned
api --> portal : Return prescription details
portal --> pharmacist : Display prescription details

pharmacist -> portal : Process prescription
portal -> api : Submit processing update
api -> db : Update prescription status
db --> api : Status updated

pharmacist -> portal : Dispense medication
portal -> api : Submit dispensing update
api -> db : Record medication dispensing
db --> api : Dispensing recorded
api --> portal : Return dispensing confirmation
portal --> pharmacist : Display dispensing confirmation

@enduml